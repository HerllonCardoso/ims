{
  "name": "in-memory-filesystem",
  "version": "0.2.0",
  "private": true,
  "description": "In-memory filesystem with a CLI and web explorer",
  "license": "MIT",
  "author": "Herllon Cardoso",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start -w @ims/cli",
    "dev": "concurrently -n server,client -c green,blue \"npm run dev -w @ims/server\" \"npm run dev -w @ims/client\"",
    "build": "tsc -b && npm run build -w @ims/client",
    "serve": "node packages/server/dist/index.js",
    "test": "jest && npm run test -w @ims/client",
    "test:watch": "jest --watch",
    "typecheck": "tsc -b --pretty",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.19.19",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0"
  }
}
